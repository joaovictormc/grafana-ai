{
  "id": null,
  "uid": "network-equipment-overview",
  "title": "Rede - Monitoramento de Equipamentos (Zabbix)",
  "description": "Visão geral de disponibilidade, performance e métricas específicas de Mikrotik, switches, roteadores e APs Unifi monitorados via Zabbix (grupo de host 'Rede').",
  "tags": ["zabbix", "rede", "network"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "1m",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "DS_ZABBIX",
        "type": "datasource",
        "label": "Datasource Zabbix",
        "query": "alexanderzobnin-zabbix-datasource",
        "current": { "text": "Zabbix", "value": "Zabbix" }
      },
      {
        "name": "group",
        "type": "constant",
        "label": "Grupo de host (Zabbix)",
        "query": "Rede",
        "current": { "text": "Rede", "value": "Rede" },
        "hide": 2
      },
      {
        "name": "mikrotik_hosts",
        "type": "custom",
        "label": "Hosts - Mikrotik",
        "query": "Mk Galpao,Mk-Firewall",
        "options": [
          { "text": "Mk Galpao", "value": "Mk Galpao", "selected": true },
          { "text": "Mk-Firewall", "value": "Mk-Firewall", "selected": true }
        ],
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": { "text": "Mk Galpao + Mk-Firewall", "value": ["Mk Galpao", "Mk-Firewall"] },
        "description": "Hosts Mikrotik. Ajuste a lista de opções caso novos equipamentos sejam adicionados."
      },
      {
        "name": "switch_router_hosts",
        "type": "custom",
        "label": "Hosts - Switches & Roteadores",
        "query": "Switch Rack 803,Switch Rack 902,Switch Rack 906,TESTI-BR-902",
        "options": [
          { "text": "Switch Rack 803", "value": "Switch Rack 803", "selected": true },
          { "text": "Switch Rack 902", "value": "Switch Rack 902", "selected": true },
          { "text": "Switch Rack 906", "value": "Switch Rack 906", "selected": true },
          { "text": "TESTI-BR-902", "value": "TESTI-BR-902", "selected": true }
        ],
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": { "text": "Switch Rack 803 + Switch Rack 902 + Switch Rack 906 + TESTI-BR-902", "value": ["Switch Rack 803", "Switch Rack 902", "Switch Rack 906", "TESTI-BR-902"] },
        "description": "Hosts switches e roteadores. Ajuste a lista de opções caso novos equipamentos sejam adicionados."
      },
      {
        "name": "ap_hosts",
        "type": "custom",
        "label": "Hosts - AP Unifi",
        "query": "U7 Pro - Centro GLP,U7 Pro - Sala 803,U7 Pro - Sala 902,U7 Pro - Sala 906,U7 Pro - Sala Dionis,U7 Pro - Sala Principal",
        "options": [
          { "text": "U7 Pro - Centro GLP", "value": "U7 Pro - Centro GLP", "selected": true },
          { "text": "U7 Pro - Sala 803", "value": "U7 Pro - Sala 803", "selected": true },
          { "text": "U7 Pro - Sala 902", "value": "U7 Pro - Sala 902", "selected": true },
          { "text": "U7 Pro - Sala 906", "value": "U7 Pro - Sala 906", "selected": true },
          { "text": "U7 Pro - Sala Dionis", "value": "U7 Pro - Sala Dionis", "selected": true },
          { "text": "U7 Pro - Sala Principal", "value": "U7 Pro - Sala Principal", "selected": true }
        ],
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": { "text": "U7 Pro - Centro GLP + U7 Pro - Sala 803 + U7 Pro - Sala 902 + U7 Pro - Sala 906 + U7 Pro - Sala Dionis + U7 Pro - Sala Principal", "value": ["U7 Pro - Centro GLP", "U7 Pro - Sala 803", "U7 Pro - Sala 902", "U7 Pro - Sala 906", "U7 Pro - Sala Dionis", "U7 Pro - Sala Principal"] },
        "description": "Hosts AP Unifi. Ajuste a lista de opções caso novos equipamentos sejam adicionados."
      },
      {
        "name": "vpn_mikrotik_host",
        "type": "custom",
        "label": "Host Mikrotik (Firewall/VPN)",
        "query": "Mk-Firewall",
        "options": [
          { "text": "Mk-Firewall", "value": "Mk-Firewall", "selected": true }
        ],
        "multi": false,
        "includeAll": false,
        "current": { "text": "Mk-Firewall", "value": "Mk-Firewall" },
        "description": "Host Mikrotik que concentra firewall e VPN (WireGuard/OpenVPN), usado nas rows de VPN."
      }
    ]
  },
  "panels": [
    { "id": 100, "type": "row", "title": "Visão Geral / Disponibilidade (todos os equipamentos)", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }, "collapsed": false },
    {
      "id": 1, "title": "Status (ICMP ping) por host", "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "datasource": { "type": "alexanderzobnin-zabbix-datasource", "uid": "${DS_ZABBIX}" },
      "targets": [{
        "refId": "A", "resultFormat": "time_series", "queryType": 0, "mode": 0,
        "group": { "filter": "$group" }, "host": { "filter": "/.*/" },
        "application": { "filter": "" }, "item": { "filter": "/ICMP ping$/" },
        "functions": []
      }],
      "fieldConfig": { "defaults": { "mappings": [
        { "type": "range", "options": { "from": 0, "to": 0.5, "result": { "text": "DOWN", "color": "red" } } },
        { "type": "range", "options": { "from": 0.5, "to": 1, "result": { "text": "UP", "color": "green" } } }
      ] } }
    },
    {
      "id": 2, "title": "Latência ICMP (ms)", "type": "timeseries",
